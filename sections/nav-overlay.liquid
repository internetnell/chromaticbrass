<style>
  /* Minimal overlay nav — fade in/out only */
  .nav {
    position: fixed;
    inset: 0;
    z-index: 999;
    width: 100%;
    height: 100vh;
    background: url('https://cdn.shopify.com/s/files/1/0757/8465/0993/files/nav-bg.png?v=1760047425') center top / cover no-repeat;
    opacity: 0;                 /* hidden by default */
    visibility: hidden;         /* keep out of a11y tree/clicks */
    pointer-events: none;       /* don't block page when closed */
    transition: opacity 700ms ease; /* slow fade in/out */
  }
  .nav.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* Keep your content above the background image */
  .nav .nav-overlay { position: relative; z-index: 1; }

  /* Basic list/link reset (optional—remove if already in theme) */
  .nav-list { list-style: none; margin: 0; padding: 0; }
  .nav-link { text-decoration: none; }
</style>

<nav class="nav js-nav" aria-hidden="true">
  <div class="nav-overlay container">
    <button type="button" class="closebtn" onclick="closeNav()">close</button>

    <ul>
      {% for link in linklists['main-nav'].links %}
        <li class="h2 nav-list">
          <a class="nav-link" href="{{ link.url }}">{{ link.title }}</a>
        </li>
      {% endfor %}
    </ul>
  </div>
</nav>

<script>
  function openNav(e){
    if(e) e.preventDefault();
    const nav = document.querySelector('.js-nav');
    const toggler = document.querySelector('.js-nav-toggler');
    if(!nav) return;
    nav.classList.add('is-open');
    nav.setAttribute('aria-hidden','false');
    if(toggler){ toggler.classList.add('active'); toggler.setAttribute('aria-expanded','true'); }
    document.body.classList.add('no-scroll');
  }

  function closeNav(e){
    if(e) e.preventDefault();
    const nav = document.querySelector('.js-nav');
    const toggler = document.querySelector('.js-nav-toggler');
    if(!nav) return;
    nav.classList.remove('is-open');
    nav.setAttribute('aria-hidden','true');
    if(toggler){ toggler.classList.remove('active'); toggler.setAttribute('aria-expanded','false'); }
    document.body.classList.remove('no-scroll');
  }

  document.addEventListener('DOMContentLoaded', () => {
    const toggler = document.querySelector('.js-nav-toggler');
    if(toggler){ toggler.addEventListener('click', openNav); }
    document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') closeNav(e); });
  });
</script>
